
#  H-SECURE — Variables d'environnement


# Mot de passe PostgreSQL (utilisateur hsecure_user)
DB_PASSWORD=ChangeMe_DbPassword!
POSTGRES_PASSWORD=ChangeMe_PostgresPassword!

# Clé secrète JWT (min 32 caractères aléatoires)
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ChangeMe_JwtSecret_AtLeast32Chars!!

# Clé de chiffrement AES-256 (Fernet — format base64 strict)
# Générer avec : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=ChangeMe_GenerateWithFernetGenerateKey=
